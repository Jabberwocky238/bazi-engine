{
  "name": "@jabberwocky238/bazi-engine",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "shishen": "bun run test/cli-shishen.ts",
    "shensha": "bun run test/cli-shensha.ts",
    "ganzhi": "bun run test/cli-ganzhi.ts",
    "clean": "rm -rf dist",
    "build": "mkdir -p dist && bun build ./src/index.ts --outdir dist --target bun && bunx tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "lunar-typescript": "^1.8.6"
  }
}
